{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs-x64",
      "displayName": "VS x64 (Ninja Multi-Config)",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "Qt6_DIR": "$env{Qt6_DIR}",
        "CMAKE_PREFIX_PATH": "$env{CMAKE_PREFIX_PATH}",
        "VOIDCARE_DISCORD_CLIENT_ID": "1479026910574153921",
        "VOIDCARE_ENABLE_TESTS": "ON",
        "VOIDCARE_BUILD_IMGUI": "ON",
        "VOIDCARE_BUILD_WPF": "OFF",
        "VOIDCARE_BUILD_BRIDGE": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs-x64-debug",
      "configurePreset": "vs-x64",
      "configuration": "Debug"
    },
    {
      "name": "vs-x64-release",
      "configurePreset": "vs-x64",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "vs-x64-release",
      "configurePreset": "vs-x64",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
