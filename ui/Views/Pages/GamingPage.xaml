<UserControl x:Class="VoidCare.Wpf.Views.Pages.GamingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VoidCare.Wpf.Converters">
    <UserControl.Resources>
        <conv:WidthToColumnsConverter x:Key="WidthToColumnsConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <UniformGrid Columns="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}, Converter={StaticResource WidthToColumnsConverter}}">
                <Border Style="{StaticResource PremiumCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Gaming Boost" />
                        <TextBlock Text="High performance plan and safe gaming toggles." Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12" />
                        <WrapPanel>
                            <Button Style="{StaticResource PrimaryButtonStyle}" Content="Enable Boost" Command="{Binding EnableGamingBoostCommand}" Margin="0,0,8,0" />
                            <Button Style="{StaticResource DangerButtonStyle}" Content="Revert" Command="{Binding RevertGamingBoostCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PremiumCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="State" />
                        <TextBlock Text="Use Revert or restore point to undo gaming changes." Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource PremiumCardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Logs" Margin="0" DockPanel.Dock="Left" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Clear" Command="{Binding ClearLogsCommand}" DockPanel.Dock="Right" />
                    </DockPanel>
                    <ListBox ItemsSource="{Binding Logs}" Height="220" Background="#111624" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="12" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
