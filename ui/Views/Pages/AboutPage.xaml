<UserControl x:Class="VoidCare.Wpf.Views.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VoidCare.Wpf.Converters">
    <UserControl.Resources>
        <conv:WidthToColumnsConverter x:Key="WidthToColumnsConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <UniformGrid Columns="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}, Converter={StaticResource WidthToColumnsConverter}}">
                <Border Style="{StaticResource PremiumCardStyle}">
                    <StackPanel>
                        <TextBlock Text="VoidCare" FontSize="40" FontWeight="Bold" />
                        <TextBlock Text="by VoidTools" Foreground="{StaticResource MutedTextBrush}" FontSize="16" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding CreditsText}" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PremiumCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Discord" />
                        <TextBlock Text="{Binding DiscordAboutStatus}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource PremiumCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Safety Notes" />
                    <TextBlock Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Text="Administrator-only launch, offline-only behavior, Defender-only auto-remediation, and quarantine-first suspicious workflow remain enforced." />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
