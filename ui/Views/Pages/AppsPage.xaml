<UserControl x:Class="VoidCare.Wpf.Views.Pages.AppsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VoidCare.Wpf.Converters">
    <UserControl.Resources>
        <conv:WidthToColumnsConverter x:Key="WidthToColumnsConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource PremiumCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Apps Manager (Inventory + Launchers)" Margin="0" VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Refresh Apps" Command="{Binding RefreshAppsCommand}" Margin="0,0,8,0" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Apps Settings" Command="{Binding OpenAppsSettingsCommand}" Margin="0,0,8,0" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Programs &amp; Features" Command="{Binding OpenProgramsFeaturesCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource PremiumCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Installed Apps" />
                    <DataGrid Style="{StaticResource ModernDataGridStyle}" ItemsSource="{Binding InstalledApps}" Height="420">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="120" />
                            <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="220" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
