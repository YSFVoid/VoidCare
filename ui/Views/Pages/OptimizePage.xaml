<UserControl x:Class="VoidCare.Wpf.Views.Pages.OptimizePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VoidCare.Wpf.Converters">
    <UserControl.Resources>
        <conv:WidthToColumnsConverter x:Key="WidthToColumnsConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <UniformGrid Columns="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}, Converter={StaticResource WidthToColumnsConverter}}">
                <Border Style="{StaticResource PremiumCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Safe Optimization" />
                        <TextBlock Text="Temp cleanup and recycle-bin cleanup with restore-point guard." Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12" TextWrapping="Wrap" />
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Run Safe Cleanup" Command="{Binding RunSafeOptimizationCommand}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PremiumCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Aggressive Options" />
                        <CheckBox Content="Optional bloat removal" IsChecked="{Binding RemoveBloat}" Margin="0,0,0,8" />
                        <CheckBox Content="Disable Copilot (best-effort)" IsChecked="{Binding DisableCopilot}" Margin="0,0,0,12" />
                        <Button Style="{StaticResource DangerButtonStyle}" Content="Run Aggressive" Command="{Binding RunAggressiveOptimizationCommand}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource PremiumCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Status" />
                    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#A5EFC2" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                        <Setter Property="Foreground" Value="#FFB8C5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PremiumCardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Logs" Margin="0" DockPanel.Dock="Left" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Clear" Command="{Binding ClearLogsCommand}" DockPanel.Dock="Right" />
                    </DockPanel>
                    <ListBox ItemsSource="{Binding Logs}" Height="220" Background="#111624" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="12" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
