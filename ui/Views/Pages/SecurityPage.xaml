<UserControl x:Class="VoidCare.Wpf.Views.Pages.SecurityPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VoidCare.Wpf.Converters">
    <UserControl.Resources>
        <conv:WidthToColumnsConverter x:Key="WidthToColumnsConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource StatusChipStyle}" Margin="0,0,0,12" Background="#5F2738" BorderBrush="#A94A68">
                <TextBlock Text="{Binding WarningBannerText}" Foreground="#FFEAF0" FontWeight="SemiBold" />
            </Border>

            <UniformGrid Columns="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}, Converter={StaticResource WidthToColumnsConverter}}">
                <Border Style="{StaticResource PremiumCardStyle}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Defender Scans" Margin="0" DockPanel.Dock="Left" />
                            <Border Style="{StaticResource StatusChipStyle}" DockPanel.Dock="Right">
                                <TextBlock Text="Defender Scan Availability">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Defender scans unavailable" />
                                            <Setter Property="Foreground" Value="#FFB8C5" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DefenderScanAvailable}" Value="True">
                                                    <Setter Property="Text" Value="Defender scans available" />
                                                    <Setter Property="Foreground" Value="#A5EFC2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DockPanel>

                        <WrapPanel Margin="0,0,0,8">
                            <Button Style="{StaticResource PrimaryButtonStyle}" Content="Quick" Command="{Binding DefenderQuickScanCommand}" Margin="0,0,8,8" />
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Full" Command="{Binding DefenderFullScanCommand}" Margin="0,0,8,8" />
                            <Button Style="{StaticResource DangerButtonStyle}" Content="Auto-Remediate" Command="{Binding DefenderAutoRemediateCommand}" Margin="0,0,8,8" />
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Refresh AV" Command="{Binding RefreshAntivirusCommand}" Margin="0,0,8,8" />
                        </WrapPanel>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Margin="0,0,8,0" Height="{StaticResource ControlHeight}" Text="{Binding CustomScanPath}" Style="{StaticResource SearchBoxStyle}" />
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Scan Path" Command="{Binding DefenderCustomScanCommand}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Margin="0,0,8,0" Height="{StaticResource ControlHeight}" Text="{Binding ExternalExe}" Style="{StaticResource SearchBoxStyle}" />
                            <TextBox Grid.Column="1" Margin="0,0,8,0" Height="{StaticResource ControlHeight}" Text="{Binding ExternalArgs}" Style="{StaticResource SearchBoxStyle}" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Set" Command="{Binding ConfigureExternalScannerCommand}" Margin="0,0,8,0" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Run" Command="{Binding RunExternalScannerCommand}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PremiumCardStyle}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <DockPanel>
                                <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Persistence Audit" Margin="0" DockPanel.Dock="Left" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource SecondaryButtonStyle}" Content="Refresh" Command="{Binding RefreshPersistenceAuditCommand}" Margin="0,0,8,0" />
                                    <Button Style="{StaticResource DangerButtonStyle}" Content="Disable Selected" Command="{Binding DisablePersistenceEntryCommand}" />
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>

                        <DataGrid Style="{StaticResource ModernDataGridStyle}"
                                  ItemsSource="{Binding PersistenceEntries}"
                                  SelectedItem="{Binding SelectedPersistenceEntry, Mode=TwoWay}"
                                  Height="280">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Source" Binding="{Binding SourceType}" Width="120" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="140" />
                                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                                <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="130" />
                                <DataGridTextColumn Header="Signature" Binding="{Binding SignatureStatus}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource PremiumCardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Suspicious Files" Margin="0" DockPanel.Dock="Left" />
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Quick Scan" Command="{Binding QuickSuspiciousScanCommand}" Margin="0,0,8,0" />
                            <TextBox Width="260" Height="{StaticResource ControlHeight}" Margin="0,0,8,0" Style="{StaticResource SearchBoxStyle}" Text="{Binding FullScanRoots}" />
                            <Button Style="{StaticResource SecondaryButtonStyle}" Content="Full Scan" Command="{Binding FullSuspiciousScanCommand}" />
                        </StackPanel>
                    </DockPanel>

                    <WrapPanel Margin="0,0,0,8">
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Quarantine Selected" Command="{Binding QuarantineSelectedCommand}" Margin="0,0,8,8" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Restore Quarantined" Command="{Binding RestoreQuarantinedCommand}" Margin="0,0,8,8" />
                        <Button Style="{StaticResource DangerButtonStyle}" Content="Delete Quarantined" Command="{Binding DeleteQuarantinedCommand}" Margin="0,0,8,8" />
                    </WrapPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ItemsSource="{Binding SuspiciousEntries}"
                                  Height="280">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Sel" Binding="{Binding IsSelected}" Width="45" />
                                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                                <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="60" />
                                <DataGridTextColumn Header="Signature" Binding="{Binding SignatureStatus}" Width="110" />
                                <DataGridTextColumn Header="Reasons" Binding="{Binding Reasons}" Width="220" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DataGrid Grid.Column="2"
                                  Style="{StaticResource ModernDataGridStyle}"
                                  ItemsSource="{Binding QuarantineEntries}"
                                  Height="280">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Sel" Binding="{Binding IsSelected}" Width="45" />
                                <DataGridTextColumn Header="Original Path" Binding="{Binding OriginalPath}" Width="*" />
                                <DataGridTextColumn Header="Quarantine Path" Binding="{Binding QuarantinePath}" Width="*" />
                                <DataGridTextColumn Header="Signature" Binding="{Binding SignatureStatus}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PremiumCardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource CardHeaderTextStyle}" Text="Logs" Margin="0" DockPanel.Dock="Left" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Clear" Command="{Binding ClearLogsCommand}" DockPanel.Dock="Right" />
                    </DockPanel>

                    <ListBox ItemsSource="{Binding Logs}"
                             Height="220"
                             Background="#111624"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Foreground="{StaticResource TextBrush}"
                             FontFamily="Consolas"
                             FontSize="12" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
