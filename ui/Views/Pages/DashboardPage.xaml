<UserControl x:Class="VoidCare.Wpf.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VoidCare.Wpf.Converters">
    <UserControl.Resources>
        <conv:WidthToColumnsConverter x:Key="WidthToColumnsConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource PremiumCardStyle}"
                    Margin="0,0,0,12"
                    Padding="14,10">
                <DockPanel>
                    <TextBlock Text="{Binding HealthSummary}"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <Border DockPanel.Dock="Left"
                            Margin="0,0,12,0"
                            Padding="10,3"
                            CornerRadius="10"
                            Background="#2A3351"
                            BorderBrush="#4D5D9AFF"
                            BorderThickness="1">
                        <TextBlock Text="Session Overview"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                    </Border>
                </DockPanel>
            </Border>

            <UniformGrid Columns="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}, Converter={StaticResource WidthToColumnsConverter}}">
                <Border Style="{StaticResource PremiumCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="108" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="System Health" Style="{StaticResource CardHeaderTextStyle}" />
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource StatusChipStyle}">
                                <TextBlock Text="Live"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource MiniStatTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="CPU" Style="{StaticResource CardLabelTextStyle}" />
                                    <TextBlock Text="{Binding CpuStatValue}" Style="{StaticResource CardValueTextStyle}" FontSize="18" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource MiniStatTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="RAM" Style="{StaticResource CardLabelTextStyle}" />
                                    <TextBlock Text="{Binding RamStatValue}" Style="{StaticResource CardValueTextStyle}" FontSize="18" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource MiniStatTileStyle}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="Disk" Style="{StaticResource CardLabelTextStyle}" />
                                    <TextBlock Text="{Binding DiskStatValue}" Style="{StaticResource CardValueTextStyle}" FontSize="18" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Last scan" Style="{StaticResource CardLabelTextStyle}" />
                                <TextBlock Text="{Binding LastScanText}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Last optimize" Style="{StaticResource CardLabelTextStyle}" />
                                <TextBlock Text="{Binding LastOptimizeText}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="3"
                                CornerRadius="12"
                                BorderBrush="#2F4067A5"
                                BorderThickness="1"
                                Background="#111A2A"
                                Margin="0,0,0,12">
                            <Grid>
                                <Polyline Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="2"
                                          Opacity="0.9"
                                          Margin="12,8,12,18"
                                          Points="0,62 42,48 84,50 126,38 168,44 210,28 252,40 294,24 336,34 378,18" />
                                <StackPanel VerticalAlignment="Bottom" Margin="12,0,12,12">
                                    <Rectangle Width="180" Style="{StaticResource SkeletonBarStyle}" Margin="0,0,0,6" />
                                    <Rectangle Width="140" Style="{StaticResource SkeletonBarStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="4"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Quick Suspicious Scan"
                                    Command="{Binding QuickSuspiciousScanCommand}"
                                    Margin="0,0,8,0" />
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Refresh Health"
                                    Command="{Binding RefreshHealthCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PremiumCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Antivirus" Style="{StaticResource CardHeaderTextStyle}" />
                            <Border DockPanel.Dock="Right">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource StatusChipStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AntivirusChipState}" Value="Active">
                                                <Setter Property="Background" Value="#264D3A" />
                                                <Setter Property="BorderBrush" Value="#53D694" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AntivirusChipState}" Value="Passive">
                                                <Setter Property="Background" Value="#3C3348" />
                                                <Setter Property="BorderBrush" Value="#8C7CD5" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding AntivirusChipState}" Value="Unavailable">
                                                <Setter Property="Background" Value="#4A2D35" />
                                                <Setter Property="BorderBrush" Value="#D46F82" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding AntivirusChipState}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Provider" Style="{StaticResource CardLabelTextStyle}" />
                                <TextBlock Text="{Binding AntivirusProviderName}" FontWeight="Bold" FontSize="18" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                <TextBlock Text="Status detail" Style="{StaticResource CardLabelTextStyle}" />
                                <TextBlock Text="{Binding AntivirusStatus}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Last scan" Style="{StaticResource CardLabelTextStyle}" />
                                <TextBlock Text="{Binding LastScanText}" FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2"
                                Margin="0,0,0,12"
                                Padding="10,6"
                                CornerRadius="10">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource StatusChipStyle}">
                                    <Setter Property="Background" Value="#4A2D35" />
                                    <Setter Property="BorderBrush" Value="#D46F82" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DefenderScanAvailable}" Value="True">
                                            <Setter Property="Background" Value="#2A3551" />
                                            <Setter Property="BorderBrush" Value="#6A7EFF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Defender scans unavailable (use external scanner if managed by 3rd-party AV)." />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DefenderScanAvailable}" Value="True">
                                                <Setter Property="Text" Value="Defender scans available for this session." />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Refresh AV"
                                    Command="{Binding RefreshAntivirusCommand}"
                                    Margin="0,0,8,0" />
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Quick Scan"
                                    Command="{Binding DefenderQuickScanCommand}"
                                    Margin="0,0,8,0" />
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Full Scan"
                                    Command="{Binding DefenderFullScanCommand}"
                                    Margin="0,0,8,0" />
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Auto-Remediate"
                                    Command="{Binding DefenderAutoRemediateCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PremiumCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Operations"
                                   Style="{StaticResource CardHeaderTextStyle}"
                                   Margin="0,0,0,12" />

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Refresh persistence audit" Style="{StaticResource CardLabelTextStyle}" VerticalAlignment="Center" />
                            <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Run" Command="{Binding RefreshPersistenceAuditCommand}" Margin="10,0,0,8" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Run safe optimization" Style="{StaticResource CardLabelTextStyle}" VerticalAlignment="Center" />
                            <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Run" Command="{Binding RunSafeOptimizationCommand}" Margin="10,0,0,8" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Enable gaming boost" Style="{StaticResource CardLabelTextStyle}" VerticalAlignment="Center" />
                            <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Run" Command="{Binding EnableGamingBoostCommand}" Margin="10,0,0,8" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Refresh apps inventory" Style="{StaticResource CardLabelTextStyle}" VerticalAlignment="Center" />
                            <Button Grid.Row="3" Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Content="Run" Command="{Binding RefreshAppsCommand}" Margin="10,0,0,0" />
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <Rectangle Width="220" Style="{StaticResource SkeletonBarStyle}" Margin="0,0,0,6" />
                            <Rectangle Width="260" Style="{StaticResource SkeletonBarStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PremiumCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Session Status"
                                   Style="{StaticResource CardHeaderTextStyle}"
                                   Margin="0,0,0,12" />

                        <Border Grid.Row="1"
                                Background="#131B2B"
                                BorderBrush="#32456D9B"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Latest action result"
                                           Style="{StaticResource CardLabelTextStyle}" />
                                <TextBlock Text="{Binding StatusText}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Feed placeholder"
                                       Style="{StaticResource CardLabelTextStyle}"
                                       Margin="0,0,0,8" />
                            <Rectangle Width="240" Style="{StaticResource SkeletonBarStyle}" Margin="0,0,0,6" />
                            <Rectangle Width="300" Style="{StaticResource SkeletonBarStyle}" Margin="0,0,0,6" />
                            <Rectangle Width="180" Style="{StaticResource SkeletonBarStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
