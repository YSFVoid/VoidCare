<Window x:Class="VoidCare.Wpf.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VoidCare"
        Width="1420"
        Height="900"
        MinWidth="1120"
        MinHeight="760"
        Background="{StaticResource WindowBackdropBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SurfaceGlassBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="8">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <Border Height="58"
                            CornerRadius="14"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Background="#1A2237"
                            Margin="0,0,0,14">
                        <Grid>
                            <Ellipse Width="34"
                                     Height="34"
                                     Fill="{StaticResource AccentBrush}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Effect="{StaticResource SidebarActiveGlowEffect}" />
                            <TextBlock Text="VC"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Tag="Dashboard"
                            ToolTip="Dashboard"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Dashboard">
                        <TextBlock Text="&#xE80F;" Style="{StaticResource SidebarIconTextStyle}" />
                    </Button>
                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Tag="Security"
                            ToolTip="Security"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Security">
                        <TextBlock Text="&#xE72E;" Style="{StaticResource SidebarIconTextStyle}" />
                    </Button>
                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Tag="Optimize"
                            ToolTip="Optimize"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Optimize">
                        <TextBlock Text="&#xE7EF;" Style="{StaticResource SidebarIconTextStyle}" />
                    </Button>
                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Tag="Gaming"
                            ToolTip="Gaming"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Gaming">
                        <TextBlock Text="&#xE7FC;" Style="{StaticResource SidebarIconTextStyle}" />
                    </Button>
                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Tag="Apps"
                            ToolTip="Apps"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Apps">
                        <TextBlock Text="&#xE71D;" Style="{StaticResource SidebarIconTextStyle}" />
                    </Button>
                    <Button Style="{StaticResource SidebarNavButtonStyle}"
                            Tag="About"
                            ToolTip="About"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="About">
                        <TextBlock Text="&#xE946;" Style="{StaticResource SidebarIconTextStyle}" />
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Border Height="30"
                            Margin="0,12,0,8"
                            CornerRadius="14"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Background="#1A2236">
                        <TextBlock Text="{Binding DiscordEnabled, StringFormat=Discord RPC: {0}}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </Border>
                    <TextBlock Text="Developed by Ysf (Lone Wolf Developer)"
                               TextWrapping="Wrap"
                               FontSize="9"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextAlignment="Center"
                               Margin="2,0,2,4" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="12,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="80" />
                <RowDefinition Height="*" />
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceGlassBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="186" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding CurrentPage}"
                               Style="{StaticResource DashboardTitleTextStyle}"
                               VerticalAlignment="Center" />

                    <TextBox Grid.Column="1"
                             Margin="12,0,10,0"
                             Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox Grid.Column="2"
                              Margin="0,0,10,0"
                              ItemsSource="{Binding ConfigOptions}"
                              SelectedItem="{Binding SelectedConfig}"
                              Style="{StaticResource DarkComboBoxStyle}" />

                    <ToggleButton Grid.Column="3"
                                  IsChecked="{Binding DiscordEnabled}"
                                  Style="{StaticResource ToggleSwitchStyle}" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,12,0,12"
                    Background="{StaticResource SurfaceGlassBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">
                <ContentControl x:Name="PageContentHost" />
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceGlassBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,0">
                <TextBlock Text="{Binding FooterText}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" />
            </Border>
        </Grid>
    </Grid>
</Window>
